{
  "name": "bloodmate/bloodmate",
  "description": "BloodMate - Blood Donation Management System",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "BloodMate Team",
      "email": "info@bloodmate.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "ext-pdo": "*",
    "ext-mbstring": "*",
    "ext-json": "*",
    "ext-curl": "*",
    "phpmailer/phpmailer": "^6.8",
    "firebase/php-jwt": "^6.10"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "BloodMate\\": "src/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "cs-check": "phpcs --standard=PSR12 src/",
    "cs-fix": "phpcbf --standard=PSR12 src/"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
